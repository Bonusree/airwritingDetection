GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxx
GITHUB_REPO=your-github-username/airwriting
GITHUB_BRANCH=main
GITHUB_OUTPUT_DIR=output

# Optional. If set, users must enter this key in the app before uploads work.
UPLOAD_SECRET=

# Optional. Only needed if a different website will call this API.
ALLOWED_ORIGIN=

# Optional. Keep samples small because serverless hosts have request-size limits.
MAX_SAMPLE_BYTES=10485760
